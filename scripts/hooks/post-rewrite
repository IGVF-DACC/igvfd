#!/bin/bash
#
# post-rewrite hook: detects when OpenSearch mapping files were
# modified during a rebase and prompts the user to regenerate them.
#
# Install:
#   cp scripts/hooks/post-rewrite .git/hooks/post-rewrite
#   chmod +x .git/hooks/post-rewrite

MAPPING_DIR="src/igvfd/mappings"

# Collect all old commit SHAs from stdin (provided by git).
old_shas=()
while read -r old_sha new_sha; do
    old_shas+=("$old_sha")
done

# Check if any mapping files differ between pre-rebase and current HEAD.
# The first old SHA's parent approximates the pre-rebase base.
if [ ${#old_shas[@]} -eq 0 ]; then
    exit 0
fi

# Check if any mapping files were changed in the rebase.
changed_mappings=$(git diff --name-only HEAD@{1} HEAD -- "$MAPPING_DIR" 2>/dev/null)

if [ -z "$changed_mappings" ]; then
    exit 0
fi

echo ""
echo "========================================================"
echo "  OpenSearch mapping files were modified during rebase."
echo "========================================================"
echo ""
echo "Changed files:"
echo "$changed_mappings" | sed 's/^/  /'
echo ""

# Check if stdin is a terminal (interactive).
if [ -t 0 ] || [ -t 1 ]; then
    read -r -p "Regenerate mappings now? [Y/n] " response < /dev/tty
    case "$response" in
        [nN]|[nN][oO])
            echo ""
            echo "Skipped. Run manually when ready:"
            echo "  docker compose run pyramid /scripts/pyramid/generate-opensearch-mappings.sh"
            echo ""
            exit 0
            ;;
    esac

    echo ""
    echo "Regenerating OpenSearch mappings..."
    echo ""

    docker compose run pyramid /scripts/pyramid/generate-opensearch-mappings.sh

    if [ $? -eq 0 ]; then
        git add "$MAPPING_DIR"/*.json
        git commit -m "Regenerate OpenSearch mappings after rebase"
        echo ""
        echo "Mappings regenerated and committed."
    else
        echo ""
        echo "Mapping generation failed. Please regenerate manually:"
        echo "  docker compose run pyramid /scripts/pyramid/generate-opensearch-mappings.sh"
    fi
else
    # Non-interactive: just print the warning.
    echo "Run the following command to regenerate:"
    echo "  docker compose run pyramid /scripts/pyramid/generate-opensearch-mappings.sh"
    echo ""
fi
