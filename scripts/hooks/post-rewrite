#!/bin/bash
#
# post-rewrite hook: detects when OpenSearch mapping files were
# modified during a rebase and prompts the user to regenerate them.
#
# Install:
#   cp scripts/hooks/post-rewrite .git/hooks/post-rewrite
#   chmod +x .git/hooks/post-rewrite

# Only act on rebase, not amend.
if [ "$1" != "rebase" ]; then
    exit 0
fi

MAPPING_DIR="src/igvfd/mappings"

# Drain stdin (git provides old/new SHA pairs, we don't need them).
cat > /dev/null

# ORIG_HEAD points to where the branch was before the rebase.
# Compare it against current HEAD to detect mapping changes.
changed_mappings=$(git diff --name-only ORIG_HEAD HEAD -- "$MAPPING_DIR" 2>/dev/null)

if [ -z "$changed_mappings" ]; then
    exit 0
fi

# Source the shared prompt logic.
HOOK_DIR="$(dirname "$0")"
. "$HOOK_DIR/prompt-mapping-regen.sh"
